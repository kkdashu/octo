# Feishu App Credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_ENCRYPT_KEY=xxx

# Main group chat ID (from Feishu)
MAIN_GROUP_CHAT_ID=oc_xxx

# Anthropic API Key (for Claude Agent SDK)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI-compatible upstreams
OPENAI_API_KEY=sk-xxx
MOONSHOT_API_KEY=sk-xxx

# Agent profile config
AGENT_PROFILES_PATH=config/agent-profiles.json
OPENAI_PROXY_PORT=9901

# Server port
PORT=3000
ADMIN_PORT=3010

# Log level (debug | info | warn | error)
LOG_LEVEL=debug

# Log file directory (default: store/logs)
LOG_DIR=store/logs

# Timezone for scheduler cron (default: Asia/Shanghai)
TZ=Asia/Shanghai
