{
  "name": "mini_cowork",
  "version": "0.1.0",
  "description": "Standalone multi-provider Claude Agent SDK runner with OpenAI-compatible proxy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mini-cowork": "dist/cli.js"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "build:watch": "node node_modules/typescript/bin/tsc --watch",
    "test": "node --test tests/*.test.mjs",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "*",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "anthropic",
    "ai",
    "cli",
    "openai-compatible",
    "multi-provider"
  ],
  "license": "MIT"
}
